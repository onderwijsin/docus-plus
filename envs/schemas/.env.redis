# @defaultRequired=infer
# @defaultSensitive=false
# ---

# Optional Redis connection URL for the node-server cache backend.
# When no Redis settings are provided, the cache module uses Nitro's memory driver.
# @optional
# @sensitive
# @type=url
# @example="rediss://default:MySecurePassword123@redis.example.com:6380"
REDIS_URL=

# Redis host used when `REDIS_URL` is not provided.
# @public
# @optional
# @example="redis.example.com"
REDIS_HOST=

# Redis port used when `REDIS_URL` is not provided.
# @public
# @optional
# @type=port
# @example="6380"
REDIS_PORT=

# Redis username used when `REDIS_URL` is not provided.
# @optional
# @example="default"
REDIS_USERNAME=

# Redis password used when `REDIS_URL` is not provided.
# @optional
# @sensitive
# @example="MySecurePassword123"
REDIS_PASSWORD=

# Redis database index used by the cache module.
# @public
# @optional
# @type=number
# @example="0"
REDIS_DB=

# Enable TLS for split Redis host and port configuration.
# @public
# @optional
# @type=boolean
REDIS_TLS=

# Disable TLS certificate validation only when the environment requires it.
# @public
# @optional
# @type=boolean
REDIS_TLS_REJECT_UNAUTHORIZED=
