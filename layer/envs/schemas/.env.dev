# @defaultRequired=infer
# @defaultSensitive=false
# ---

# Enable verbose build-time debugging across Nuxt and local modules.
# @public
# @type=boolean
DEBUG=false

# Skip local format checks in git hooks when explicitly overridden.
# @public
# @optional
# @type=boolean
DISABLE_PRE_COMMIT_FORMAT=

# Skip local lint checks in git hooks when explicitly overridden.
# @public
# @optional
# @type=boolean
DISABLE_PRE_COMMIT_LINT=

# Skip local typecheck in the pre-commit hook when explicitly overridden.
# @public
# @optional
# @type=boolean
DISABLE_PRE_COMMIT_TYPECHECK=

# Skip local typecheck in the pre-push hook when explicitly overridden.
# @public
# @optional
# @type=boolean
DISABLE_PRE_PUSH_TYPECHECK=

# Skip local formatting in the pre-push hook when explicitly overridden.
# @public
# @optional
# @type=boolean
DISABLE_PRE_PUSH_FORMAT=

# Skip local lint checks in the pre-push hook when explicitly overridden.
# @public
# @optional
# @type=boolean
DISABLE_PRE_PUSH_LINT=

# Nuxt and Vitest helper flag.
# @public
# @optional
# @type=boolean
# @auditIgnore
VITEST=

# Nuxt test-utils helper flag.
# @public
# @optional
# @type=boolean
# @auditIgnore
NUXT_TEST=

# Node execution mode used in a few build-time checks.
# @public
# @optional
# @type=enum(development, test, production)
# @auditIgnore
NODE_ENV=
