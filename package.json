{
  "name": "docus-plus-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @onderwijsin/docus-plus-docs dev",
    "docs:dev": "pnpm --filter @onderwijsin/docus-plus-docs dev",
    "docs:build": "pnpm --filter @onderwijsin/docus-plus-docs build",
    "playground:dev": "pnpm --filter docus-plus-playground dev",
    "playground:build": "pnpm --filter docus-plus-playground build",
    "cli:build": "pnpm --filter create-docus-plus build",
    "cli:test": "pnpm --filter create-docus-plus test",
    "dev:prepare": "pnpm --filter @onderwijsin/docus-plus dev:prepare && pnpm --filter @onderwijsin/docus-plus-docs dev:prepare && pnpm --filter docus-plus-playground dev:prepare",
    "typecheck": "pnpm --filter create-docus-plus typecheck && pnpm --filter @onderwijsin/docus-plus typecheck && pnpm --filter @onderwijsin/docus-plus-docs typecheck && pnpm --filter docus-plus-playground typecheck",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "build": "pnpm cli:build && pnpm docs:build && pnpm playground:build",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "semantic-release": "^25.0.6"
  },
  "packageManager": "pnpm@11.11.0"
}
