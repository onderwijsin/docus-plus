# @defaultRequired=infer
# @defaultSensitive=false
# ---

# Redis connection URL for the node-server cache backend.
# Must be set for node-server present in non-dev environments.
# @required=not(forEnv(development))
# @sensitive
# @type=url
# @example="rediss://default:MySecurePassword123@redis.example.com:6380"
REDIS_URL=protonPass(concat(pass://${PROTON_VAULT}/, $APP_ENV, /REDIS_URL), allowMissing=true)

# Disable TLS certificate validation only when the environment requires it.
# @public
# @optional
# @type=boolean
REDIS_TLS_REJECT_UNAUTHORIZED=protonPass(concat(pass://${PROTON_VAULT}/, $APP_ENV, /REDIS_TLS_REJECT_UNAUTHORIZED), allowMissing=true)
