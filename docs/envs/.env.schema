# @currentEnv=$APP_ENV
# @defaultRequired=infer
# @defaultSensitive=false
# @generateTypes(lang=ts, path=./env.d.ts)
# 
# @preventLeaks=forEnv('development')
# @redactLogs=forEnv('development')
# 
# @plugin(@varlock/proton-pass-plugin)
# @initProtonPass(personalAccessToken=$PROTON_PASS_PERSONAL_ACCESS_TOKEN)
# 
# Import sub schema's. These mirror the section names in Proton Pass vault. 
# @import(./schemas/.env.dev)
# @import(./schemas/.env.core)
# @import(./schemas/.env.docus)
# ---

# Active tracked env profile used by Varlock to load `.env.development`, `.env.preview`, `.env.production`, or `.env.next`.
# Test runs intentionally resolve to the development profile.
# @public
# @type=enum(development, preview, production, next)
# @auditIgnore
# @docs(https://varlock.dev/guides/environments/)
APP_ENV=if(eq($MODE, test), development, $MODE)

# Shared Proton Pass vault containing environment-specific items.
# @required
# @type=string(startsWith=app-)
# @example="app-my-awesome-app"
PROTON_VAULT=

# Proton Pass personal access token used in CI or other non-interactive environments.
# @required=eq($VARLOCK_IS_CI, true)
# @sensitive
# @type=protonPassPersonalAccessToken
# @example="pst_xxxx...xxxx::TOKENKEY"
# @docs(https://protonpass.github.io/pass-cli/commands/personal-access-token/)
PROTON_PASS_PERSONAL_ACCESS_TOKEN=

# Application environment consumed by the Nuxt config and runtime projection helpers.
# `test` is accepted for Vitest and Nuxt test-utils and resolves through the codebase as `development`.
# @public
# @required
# @type=enum(development, preview, production, test)
MODE=development

# Flag indicating whether the application is currently being built.
# 
# @public
# @optional
# @type=boolean
BUILD=